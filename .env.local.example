NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Wine lookup source for autofill. Options: "sampleapis" (default, free/no-auth)
# or "manual" (no external calls; search returns nothing, manual entry only).
# A paid vendor drops in as another provider in lib/wine-lookup/.
WINE_LOOKUP_PROVIDER=sampleapis
